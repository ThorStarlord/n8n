# N8N_BASE_URL — the base URL of your n8n instance (no trailing slash)
N8N_BASE_URL=http://76.13.230.200:5678

# N8N_API_KEY — generate from n8n Settings → API Keys
N8N_API_KEY=your-api-key-here

# N8N_PROJECT_ID — optional, scope to a specific project
# Leave blank to use your personal project
N8N_PROJECT_ID=
