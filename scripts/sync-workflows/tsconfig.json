{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"outDir": "./dist",
		"rootDir": "."
	},
	"include": ["*.ts"],
	"exclude": ["node_modules", "dist"]
}
